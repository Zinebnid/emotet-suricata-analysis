# ============================================
# Custom Suricata Rules — Emotet C2 Detection
# Author: Zineb Nid
# Date: 2021-01-06
# PCAP: Example-1-2021-01-06-Emotet-infection.pcap
# ============================================

# Rule 1: Detect Emotet C2 POST beaconing pattern
# Targets the random multi-segment URL structure used by Emotet
# Fired 19 alerts against confirmed C2 servers during analysis
alert http any any -> any any (
  msg:"CUSTOM - Emotet C2 POST Beacon Detected";
  flow:established,to_server;
  content:"POST";
  http_method;
  pcre:"/^\/[a-z0-9]{4,20}\/[a-z0-9]{4,20}\//Ui";
  sid:9000001;
  rev:1;
)

# Rule 2: Detect outbound traffic to confirmed Emotet C2 IP
alert tcp any any -> 5.2.136.90 any (
  msg:"CUSTOM - Known Emotet C2 Server Contact (5.2.136.90)";
  flow:established,to_server;
  sid:9000002;
  rev:1;
)

# Rule 3: Detect outbound traffic to second confirmed Emotet C2 IP
alert tcp any any -> 167.71.4.0 any (
  msg:"CUSTOM - Known Emotet C2 Server Contact (167.71.4.0)";
  flow:established,to_server;
  sid:9000003;
  rev:1;
)
